{
  "name": "vscode-ghostty-config",
  "displayName": "Ghostty Config",
  "description": "Language support for Ghostty terminal config files (completion, hover, diagnostics)",
  "version": "0.1.0",
  "publisher": "ghostty",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets"
  ],
  "keywords": [
    "ghostty",
    "terminal",
    "config",
    "lsp"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ghostty-config",
        "aliases": [
          "Ghostty Config",
          "ghostty"
        ],
        "filenames": [
          "config"
        ],
        "filenamePatterns": [
          "**/ghostty/config",
          "**/.config/ghostty/config"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ghostty-config",
        "scopeName": "source.ghostty",
        "path": "./syntaxes/ghostty.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Ghostty Config",
      "properties": {
        "ghosttyConfig.serverPath": {
          "type": "string",
          "default": "ghostty-config-lsp",
          "description": "Path to the ghostty-config-lsp binary. Defaults to searching PATH."
        },
        "ghosttyConfig.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "LSP trace level for debugging."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.24.0"
  }
}
